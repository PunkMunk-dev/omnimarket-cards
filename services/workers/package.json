{
  "name": "@cardscout/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "npm --prefix ../../packages/shared run build",
    "dev": "tsx watch src/entrypoints/worker.ts",
    "prestart": "npm --prefix ../../packages/shared run build",
    "start": "node dist/entrypoints/worker.js",
    "preonce": "npm --prefix ../../packages/shared run build",
    "once": "tsx src/entrypoints/worker-once.ts",
    "prescheduler": "npm --prefix ../../packages/shared run build",
    "scheduler": "tsx src/entrypoints/scheduler.ts",
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cardscout/shared": "file:../../packages/shared",
    "@supabase/supabase-js": "^2.90.1",
    "bullmq": "^5.61.0",
    "ioredis": "^5.8.1",
    "pino": "^9.11.0",
    "pino-pretty": "^13.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
