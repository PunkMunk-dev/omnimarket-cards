# =============================================================================
# FRONTEND (Vercel / Vite)
# =============================================================================
# Find in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =============================================================================
# WORKERS / BACKEND (Railway — never expose to the browser)
# =============================================================================

# Supabase service-role key (full database access — keep secret)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Upstash, Railway Redis, or self-hosted)
REDIS_URL=redis://default:your-redis-password@your-redis-host:6379

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# Slack — use either bot token (preferred) or webhook URL
# Get bot token from: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Get webhook URL from: https://api.slack.com/apps → Incoming Webhooks
# Format: https://hooks.slack.com/services/<WORKSPACE_ID>/<CHANNEL_ID>/<TOKEN>
SLACK_WEBHOOK_URL=

# eBay Browse / Finding API
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# The-Odds-API (https://the-odds-api.com)
ODDS_API_KEY=your-odds-api-key

# =============================================================================
# WORKER RUNTIME
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info

# Number of concurrent jobs per worker process (default: 5)
WORKER_CONCURRENCY=5
