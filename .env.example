# ------------------------------
# Frontend (Vercel / Vite client)
# ------------------------------
# Safe for client bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ------------------------------
# Worker service (server-only)
# ------------------------------
# Never expose these values to the browser.
NODE_ENV=development
LOG_LEVEL=info

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=10000

# Supabase server credentials (service role key must stay secret)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Worker tuning
WORKER_CONCURRENCY=5
WORKER_SHUTDOWN_TIMEOUT_MS=10000
DEFAULT_JOB_ATTEMPTS=5
DEFAULT_BACKOFF_MS=5000
MAX_BACKOFF_MS=120000

# Scheduler (BullMQ recurring jobs)
SCHEDULER_ENABLED=true
SCHEDULER_EBAY_REFRESH_CRON=*/20 * * * *
SCHEDULER_PSA_SPREAD_CRON=*/30 * * * *
SCHEDULER_ODDS_INGESTION_CRON=*/10 * * * *
SCHEDULER_EV_CALCULATION_CRON=*/15 * * * *
SCHEDULER_LEAD_SCRAPING_CRON=0 * * * *
SCHEDULER_SLACK_ALERT_CRON=*/5 * * * *

# Optional integrations
SLACK_WEBHOOK_URL=https://example.invalid/replace-with-real-slack-webhook
